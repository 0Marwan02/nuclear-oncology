  cannulaSize           String?
  pregnancyStatus       String?
  prepNurseNotes        String?
  ga68DoseMCi           Float?
  injectionTime         DateTime?
  scanTime              DateTime?
  uptakeTime            Int?
  prostateBedRecurrence Boolean   @default(false)
