  dmHistory           Boolean?
  dmMedicationType    String?
  dmLastDoseDate      DateTime?
  hypertension        Boolean?
  hypertensionNote    String?

  prevPetDate     DateTime?
  prevPetFindings String?

  ctMriYn       Boolean?
  ctMriDate     DateTime?
  ctMriFindings String?

  // === NURSE SECTION ===
  prepWeight       Float?
  prepHeight       Float?
  prepBloodGlucose Float?
  injectionSite    String?
