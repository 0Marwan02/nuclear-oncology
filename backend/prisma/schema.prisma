  visitId               String?
  visit                 Visit?    @relation(fields: [visitId], references: [id], onUpdate: NoAction, onDelete: NoAction)
  complaint             String?
  diagnosis             String?
  psaLevel              Float?
  totalPSA              Float?
  freePSA               Float?
  psaHistory            String?
