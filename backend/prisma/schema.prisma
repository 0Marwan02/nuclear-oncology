generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider = "sqlserver"
  url      = "sqlserver://localhost:1433;database=NuclearOncology;trustServerCertificate=true;integratedSecurity=true;encrypt=false"
}

model User {
  id         String    @id @default(uuid())
  hospitalId String    @unique
  nationalId String?
  name       String
  role       String // Admin, Doctor, Nurse, Technical
  phone      String?
  gender     String?
  birthDate  DateTime?
  password   String
  isActive   Boolean   @default(true)
  createdAt  DateTime  @default(now())

  patients           Patient[]
  visits             Visit[]
  labResults         LabResult[]
  imagingResults     ImagingResult[]
  medications        Medication[]
  radiationDoses     RadiationDose[]
  auditLogs          AuditLog[]
  scanPETCTs         ScanPETCT[]
  scanPETCTReports   ScanPETCT[]      @relation("ScanPETCT_reporter")
  scanPSMAPETCTs     ScanPSMAPETCT[]
  scanPSMAReports    ScanPSMAPETCT[]  @relation("ScanPSMA_reporter")
  scanThyroids       ScanThyroid[]
  scanThyroidReports ScanThyroid[]    @relation("ScanThyroid_reporter")
  scanBones          ScanBone[]
  scanBoneReports    ScanBone[]       @relation("ScanBone_reporter")
  scanRenals         ScanRenal[]
  scanRenalReports   ScanRenal[]      @relation("ScanRenal_reporter")
  scanGastrics       ScanGastric[]
  scanGastricReports ScanGastric[]    @relation("ScanGastric_reporter")
  scanMeckels        ScanMeckel[]
  scanMeckelReports  ScanMeckel[]     @relation("ScanMeckel_reporter")
  scanCardiacs       ScanCardiac[]
  scanCardiacReports ScanCardiac[]    @relation("ScanCardiac_reporter")
  userPermissions    UserPermission[]
  fieldAudits        FieldAudit[]
}

model UserPermission {
  id         String   @id @default(uuid())
  userId     String
  user       User     @relation(fields: [userId], references: [id], onUpdate: NoAction, onDelete: NoAction)
  permission String
  granted    Boolean
  grantedBy  String
  grantedAt  DateTime @default(now())

  @@unique([userId, permission])
}

model Patient {
  id                   String   @id @default(uuid())
  nationalId           String   @unique
  name                 String
  gender               String
  birthDate            DateTime
  phone                String
  address              String
  bloodType            String
  maritalStatus        String?
  referringDoctor      String?
  referringDoctorPhone String?
  phone2               String?
  category             String?  // PET_CT | PSMA_PET_CT | GAMMA | OTHER
  subCategory          String?  // (GAMMA sub): Thyroid | Bone | Renal | Gastric | Meckel | Other
  createdAt            DateTime @default(now())
  createdBy            String
  creator              User     @relation(fields: [createdBy], references: [id], onUpdate: NoAction, onDelete: NoAction)

  visits         Visit[]
  medications    Medication[]
  scanPETCTs     ScanPETCT[]
  scanPSMAPETCTs ScanPSMAPETCT[]
  scanThyroids   ScanThyroid[]
  scanBones      ScanBone[]
  scanRenals     ScanRenal[]
  scanGastrics   ScanGastric[]
  scanMeckels    ScanMeckel[]
  scanCardiacs   ScanCardiac[]
}

model Visit {
  id        String  @id @default(uuid())
  patientId String
  patient   Patient @relation(fields: [patientId], references: [id], onUpdate: NoAction, onDelete: NoAction)

  category    String // 'PET_CT', 'PSMA_PET_CT', 'GAMMA', 'OTHER'
  subCategory String? // 'Thyroid', 'Bone', 'Renal', 'Gastric', 'Others'

  visitDate        DateTime @default(now())
  weight           Float?
  height           Float?
  bloodGlucose     Float?
  injectionSite    String?
  pregnancyStatus  String?
  bloodPressure    String?
  temperature      Float?
  generalCondition String?
  doctorNotes      String?
  nurseNotes       String?
  workflowStatus   String   @default("Pending_Doctor") // Pending_Doctor, Pending_Nurse, Pending_Technical, Completed
  recordedBy       String
  recorder         User     @relation(fields: [recordedBy], references: [id], onUpdate: NoAction, onDelete: NoAction)

  labResults     LabResult[]
  imagingResults ImagingResult[]
  radiationDoses RadiationDose[]
  scanPETCTs     ScanPETCT[]
  scanPSMAPETCTs ScanPSMAPETCT[]
  scanThyroids   ScanThyroid[]
  scanBones      ScanBone[]
  scanRenals     ScanRenal[]
  scanGastrics   ScanGastric[]
  scanMeckels    ScanMeckel[]
  scanCardiacs   ScanCardiac[]

  returnReason String?
  @@index([patientId])
  @@index([workflowStatus])
}

model LabResult {
  id             String   @id @default(uuid())
  visitId        String
  visit          Visit    @relation(fields: [visitId], references: [id], onUpdate: NoAction, onDelete: NoAction)
  testName       String
  resultValue    String
  unit           String?
  referenceRange String?
  fileUrl        String?
  uploadedBy     String
  uploader       User     @relation(fields: [uploadedBy], references: [id], onUpdate: NoAction, onDelete: NoAction)
  uploadedAt     DateTime @default(now())
}

model ImagingResult {
  id          String   @id @default(uuid())
  visitId     String
  visit       Visit    @relation(fields: [visitId], references: [id], onUpdate: NoAction, onDelete: NoAction)
  imagingType String
  bodyRegion  String
  findings    String?
  fileUrl     String?
  uploadedBy  String
  uploader    User     @relation(fields: [uploadedBy], references: [id], onUpdate: NoAction, onDelete: NoAction)
  uploadedAt  DateTime @default(now())
}

model Medication {
  id         String    @id @default(uuid())
  patientId  String
  patient    Patient   @relation(fields: [patientId], references: [id], onUpdate: NoAction, onDelete: NoAction)
  visitId    String?
  drugName   String
  dose       String
  frequency  String
  route      String
  startDate  DateTime
  endDate    DateTime?
  uploadedBy String
  uploader   User      @relation(fields: [uploadedBy], references: [id], onUpdate: NoAction, onDelete: NoAction)
  createdAt  DateTime  @default(now())
}

model RadiationDose {
  id             String   @id @default(uuid())
  visitId        String
  visit          Visit    @relation(fields: [visitId], references: [id], onUpdate: NoAction, onDelete: NoAction)
  isotopeType    String
  doseMCi        Float
  cumulativeDose Float
  recordedBy     String
  recorder       User     @relation(fields: [recordedBy], references: [id], onUpdate: NoAction, onDelete: NoAction)
  createdAt      DateTime @default(now())
}

model AuditLog {
  id        String   @id @default(uuid())
  userId    String
  user      User     @relation(fields: [userId], references: [id], onUpdate: NoAction, onDelete: NoAction)
  tableName String
  recordId  String
  action    String
  oldValues String?
  newValues String?
  timestamp DateTime @default(now())
}

model FieldAudit {
  id        String   @id @default(uuid())
  tableName String
  recordId  String
  fieldName String
  oldValue  String?
  newValue  String?
  updatedBy String
  updater   User     @relation(fields: [updatedBy], references: [id], onUpdate: NoAction, onDelete: NoAction)
  updatedAt DateTime @default(now())
}

